# Firecrawl self-host — G4 benchmark baseline. EXAMPLE ONLY. No real secrets.
# Copy to `.env` in THIS directory (benchmark/firecrawl-selfhost/.env) before
# `docker compose up`. The real `.env` is gitignored — never commit it.
#
# Defaults below reproduce a working basic scrape+crawl stack with NO paid
# dependencies (no LLM key, no paid proxy). Everything commented out is OPTIONAL
# and only needed for the degraded-without-it features noted in the README.

# ── Required / core (have working defaults baked into the compose file) ──────
PORT=3002
HOST=0.0.0.0

# Self-hosted has no Supabase, so DB auth is OFF. With auth off, the API does
# NOT require a Bearer token (you'll see a "bypassing authentication" warning —
# expected). Leave this false for the benchmark.
USE_DB_AUTHENTICATION=false

# Admin/queue UI key (http://localhost:3002/admin/<this>/queues). Local-only
# value; change it if you ever expose the port off-localhost.
BULL_AUTH_KEY=CHANGEME

# Postgres queue-backend credentials. LOCAL DEV DEFAULTS — non-secret, the DB
# port is not exposed off the compose network. Override all three together if
# you want non-default values.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# ── Optional: AI features (NOT needed for markdown scrape/crawl baseline) ────
# Enables `json`/`summary`/`extract` formats + LLM-dependent extras. Without it
# those formats are unavailable; plain markdown extraction is UNAFFECTED.
# OPENAI_API_KEY=

# ── Optional: proxy (NOT needed for the basic baseline) ─────────────────────
# Self-hosted has NO Fire-engine, so bot-protected / heavily-blocked pages will
# fail more often than cloud. A proxy mitigates some of that. Leave unset for
# the apples-to-apples markdown baseline; document if you enable it.
# PROXY_SERVER=
# PROXY_USERNAME=
# PROXY_PASSWORD=

# ── Optional: /search backend (NOT used by our scrape/crawl harness) ────────
# SEARXNG_ENDPOINT=

# ── Optional tuning ─────────────────────────────────────────────────────────
# NUM_WORKERS_PER_QUEUE=8
# CRAWL_CONCURRENT_REQUESTS=10
# MAX_CONCURRENT_JOBS=5
# BROWSER_POOL_SIZE=5
# LOGGING_LEVEL=INFO
